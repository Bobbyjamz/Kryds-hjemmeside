# ============================================================
# KrydsByg — Environment Variables
# Kopier denne fil til .env.local og udfyld værdierne.
# ============================================================

# ── KRITISKE (siden virker ikke uden disse) ────────────────────────────

# Admin login
ADMIN_USERNAME=admin
# Generer hash med: node -e "console.log(require('bcryptjs').hashSync('DIT_KODEORD',10))"
# ADMIN_PASSWORD_HASH må ikke indeholde unescaped $ — brug B64 variant hvis problemer
ADMIN_PASSWORD_HASH=
# Alternativt: base64-kodet hash (workaround for dotenv-expand der spiser $)
# Generer med: node -e "console.log(Buffer.from(require('bcryptjs').hashSync('DIT_KODEORD',10)).toString('base64'))"
ADMIN_PASSWORD_HASH_B64=

# JWT signing — MIN. 32 tegn tilfældig streng (kræves for HS256-sikkerhed)
# Generer: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=

# Upstash Redis (data-storage for hele appen)
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ── EMAIL (Resend) ─────────────────────────────────────────────────────

RESEND_API_KEY=re_...
RESEND_FROM=KrydsByg <kontakt@krydsbyg.com>
RESEND_TO=kontakt@krydsbyg.com

# ── AI / Anthropic Claude ──────────────────────────────────────────────

ANTHROPIC_API_KEY=sk-ant-...

# ── CRON (Vercel Scheduled Jobs) ───────────────────────────────────────

# Påkrævet — cron-routes afvises hvis ikke sat
# Generer: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# ── SMS (valgfri — fejler stille hvis ikke sat) ────────────────────────

# Vi bruger GatewayAPI til SMS-notifikationer til admin
GATEWAYAPI_TOKEN=
GATEWAYAPI_FROM=KrydsByg
ADMIN_PHONE=+4500000000

# Legacy SMS-konfiguration (hvis du bruger en anden udbyder)
SMS_API_KEY=
SMS_FROM=Kryds

# ── GOOGLE CALENDAR (kun til /admin/helbred) ───────────────────────────

GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary

# ── LEAD-BOT (LeadBot v2 — scrapers) ───────────────────────────────────

# Webhook-secret til HMAC validation når eksterne kilder pusher leads
LEADBOT_WEBHOOK_SECRET=

# Eksterne scraper-/enrichment-API'er (valgfri — bot fungerer med dem der er sat)
GOOGLE_PLACES_API_KEY=
APOLLO_API_KEY=
HUNTER_API_KEY=
DATAFORDELER_USERNAME=
DATAFORDELER_PASSWORD=

# Sarah daily limit (default: 15 mails pr. dag)
SARAH_DAILY_LIMIT=15

# ── DEPLOYMENT ─────────────────────────────────────────────────────────

# Sættes automatisk af Vercel — kun for lokal override
# NODE_ENV=development
